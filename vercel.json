{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/api/proxy/(.*)",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/proxy",
      "dest": "/api/proxy.js"
    },
    {
      "src": "/proxy/(.*)",
      "dest": "/api/proxy.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NODE_OPTIONS": "--no-warnings=DeprecationWarning"
  }
}
